    <h1>اختبار إضافة وحذف المفضلة</h1>
    <p>المستخدم الحالي: ID = <?php echo $userID; ?></p>
    <p><a href="user_page.php">➡️ الذهاب إلى صفحة المستخدم (لعرض المفضلة هناك)</a></p>
    <hr>

    <h2>📌 جميع الوصفات</h2>
    <div style="display: flex; flex-wrap: wrap;">
        <?php while($row = mysqli_fetch_assoc($allRecipes)): ?>
            <div class="recipe <?php echo in_array($row['id'], $favIDs) ? 'fav' : ''; ?>">
                <strong><?php echo $row['name']; ?></strong>
                <?php if(in_array($row['id'], $favIDs)): ?>
                    <br><a href="?remove=<?php echo $row['id']; ?>" class="button remove">❌ إزالة من المفضلة</a>
                <?php else: ?>
                    <br><a href="?add=<?php echo $row['id']; ?>" class="button">❤️ إضافة للمفضلة</a>
                <?php endif; ?>
            </div>
        <?php endwhile; ?>
    </div>

    <hr>
    <h2>⭐ مفضلاتي الحالية</h2>
    <?php if(mysqli_num_rows($favorites) > 0): ?>
        <ul>
        <?php while($fav = mysqli_fetch_assoc($favorites)): ?>
            <li><?php echo $fav['name']; ?> 
                <a href="?remove=<?php echo $fav['id']; ?>" style="color:red;">[حذف]</a>
            </li>
        <?php endwhile; ?>
        </ul>
    <?php else: ?>
        <p>لا توجد مفضلات حالياً.</p>
    <?php endif; ?>
